# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Anthropic (AI features — set in Netlify env vars, NOT .env.local) ───────
ANTHROPIC_API_KEY=

# ── Kroger (grocery pricing) ─────────────────────────────────────────────────
# Register at https://developer.kroger.com → My Apps → Create App
# Scope needed: product.compact
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# ── Walmart (grocery pricing) ─────────────────────────────────────────────────
# Register at https://developer.walmart.com → Getting Started
# Apply for Open API / Marketplace access
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=

# ── Instacart (cart handoff) ──────────────────────────────────────────────────
# Apply at https://docs.instacart.com/developer_platform_api/
# Provides a shoppable cart URL from your grocery list
INSTACART_API_KEY=
